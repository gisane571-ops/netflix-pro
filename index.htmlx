<!DOCTYPE html>
<html>
<body style="background:black;color:white">

<h1>NETFLIX PRO</h1>

<div id="lista"></div>

<script>

const url="https://SEU.supabase.co/rest/v1/filmes"
const key="SUA_KEY"

fetch(url,{
headers:{
apikey:key,
Authorization:"Bearer "+key
}
})
.then(r=>r.json())
.then(d=>{

d.forEach(v=>{

let video=document.createElement("video")

video.src=v.url
video.controls=true
video.width=250

document.body.appendChild(video)

})

})

</script>

</body>
</html>
